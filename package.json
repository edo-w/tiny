{
  "name": "@edo-w/tiny",
  "version": "0.2.0",
  "description": "Tiny is a typescript dependency injection library for building maintainable applications.",
  "repository": {
    "type": "git",
    "url": "https://github.com/edo-w/tiny.git"
  },
  "author": "https://github.com/juanka881",
  "license": "Apache-2.0",
  "keywords": [
    "di",
    "dependency injection",
    "typescript",
    "ioc",
    "inversion of control"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "imports": {
    "#src/*": "./dist/src/*",
    "#test/*": "./dist/test/*"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*"
  },
  "files": [
    "./dist/src/*"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "fmt": "biome format --write",
    "lint": "biome check --write",
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run",
    "testw": "vitest",
    "cover": "vitest run --coverage",
    "coverv": "start dist/.coverage/index.html",
    "release": "biome lint && pnpm build && pnpm test && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@edo-w/devconfig": "^0.8.0",
    "@vitest/coverage-v8": "^4.0.12",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.12"
  },
  "dependencies": {
    "@edo-w/xer": "^0.4.0"
  }
}
